generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OutboundChannel {
  WHATSAPP
}

enum OutboundMessageType {
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  CAMPAIGN
}

enum OutboundMessageStatus {
  PENDING
  QUEUED
  SENT
  FAILED
}

enum OutboundMessageProvider {
  WHATSAPP_NG
}

enum InboundChannel {
  WHATSAPP
}

enum InboundMessageStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum InboundMessageIntent {
  UNKNOWN
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_RESCHEDULE
}

enum NotificationEventType {
  APPOINTMENT_CONFIRMED
  APPOINTMENT_RESCHEDULE_REQUESTED
  APPOINTMENT_REMINDER_SENT
  APPOINTMENT_ACTION_LINK_USED
}

enum AppointmentActionType {
  CONFIRM_APPOINTMENT
  RESCHEDULE_APPOINTMENT
}

enum AppointmentActionTokenStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum AppointmentActionChannel {
  WHATSAPP_LINK
}

model Clinic {
  id                String            @id @default(uuid())
  nomeFantasia      String
  razaoSocial       String?
  cnpjCpf           String?
  email             String?
  telefoneComercial String?
  endereco          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  users             User[]
  patients          Patient[]
  appointments      Appointment[]
  outboundMessages  OutboundMessage[]
  inboundMessages   InboundMessage[]
  notificationEvents NotificationEvent[]
  appointmentActionTokens AppointmentActionToken[]
  patientClinicalRecords PatientClinicalRecord[]
  anamneses         Anamnesis[]
  clinicalNotes     ClinicalNote[]
  patientProcedures PatientProcedure[]
  patientDocumentMetadata PatientDocumentMetadata[]
}

model User {
  id           String    @id @default(uuid())
  clinicId     String
  clinic       Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  nome         String
  email        String    @unique
  passwordHash String
  role         String
  ativo        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@index([clinicId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Patient {
  id               String            @id @default(uuid())
  clinicId         String
  clinic           Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  nome             String
  cpf              String?
  rg               String?
  dataNascimento   DateTime?
  telefone         String?
  email            String?
  endereco         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  appointments     Appointment[]
  outboundMessages OutboundMessage[]
  inboundMessages  InboundMessage[]
  notificationEvents NotificationEvent[]
  appointmentActionTokens AppointmentActionToken[]
  clinicalRecord   PatientClinicalRecord?
  anamneses        Anamnesis[]
  clinicalNotes    ClinicalNote[]
  patientProcedures PatientProcedure[]
  patientDocumentMetadata PatientDocumentMetadata[]

  @@index([clinicId])
}

model Appointment {
  id               String            @id @default(uuid())
  clinicId         String
  clinic           Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId        String
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  profissionalId   String?
  profissionalNome String?
  dataHora         DateTime
  horaFim          DateTime?
  status           String
  confirmado       Boolean           @default(false)
  tipo             String?
  observacoes      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  outboundMessages OutboundMessage[]
  inboundMessages  InboundMessage[]
  notificationEvents NotificationEvent[]
  appointmentActionTokens AppointmentActionToken[]
  patientProcedures PatientProcedure[]

  @@index([clinicId, dataHora])
  @@index([patientId])
}

model OutboundMessage {
  id                String                  @id @default(uuid())
  clinicId          String
  clinic            Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId         String?
  patient           Patient?                @relation(fields: [patientId], references: [id], onDelete: SetNull)
  appointmentId     String?
  appointment       Appointment?            @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  channel           OutboundChannel
  type              OutboundMessageType
  phone             String
  body              String
  status            OutboundMessageStatus   @default(PENDING)
  provider          OutboundMessageProvider
  providerMessageId String?
  lastError         String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  inboundMessages   InboundMessage[]
  appointmentActionTokens AppointmentActionToken[]

  @@index([clinicId])
  @@index([patientId])
  @@index([appointmentId])
  @@index([status])
}

model InboundMessage {
  id                String               @id @default(uuid())
  clinicId          String
  clinic            Clinic               @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId         String?
  patient           Patient?             @relation(fields: [patientId], references: [id], onDelete: SetNull)
  appointmentId     String?
  appointment       Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  outboundMessageId String?
  outboundMessage   OutboundMessage?     @relation(fields: [outboundMessageId], references: [id], onDelete: SetNull)
  channel           InboundChannel
  fromPhone         String
  body              String
  normalizedBody    String
  status            InboundMessageStatus @default(RECEIVED)
  intent            InboundMessageIntent @default(UNKNOWN)
  providerMessageId String?
  processingNotes   String?
  rawPayload        Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([clinicId])
  @@index([patientId])
  @@index([appointmentId])
  @@index([outboundMessageId])
  @@index([status])
  @@unique([clinicId, providerMessageId])
}

model NotificationEvent {
  id            String                @id @default(uuid())
  clinicId      String
  clinic        Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  appointmentId String?
  appointment   Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patientId     String?
  patient       Patient?              @relation(fields: [patientId], references: [id], onDelete: SetNull)
  phone         String?
  type          NotificationEventType
  payload       Json?
  createdAt     DateTime              @default(now())

  @@index([clinicId])
  @@index([appointmentId])
  @@index([patientId])
  @@index([type])
  @@index([createdAt])
}

model AppointmentActionToken {
  id                String                       @id @default(uuid())
  clinicId          String
  clinic            Clinic                       @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId         String
  patient           Patient                      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointmentId     String
  appointment       Appointment                  @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  actionType        AppointmentActionType
  tokenHash         String                       @unique
  expiresAt         DateTime
  usedAt            DateTime?
  status            AppointmentActionTokenStatus @default(ACTIVE)
  channel           AppointmentActionChannel
  outboundMessageId String?
  outboundMessage   OutboundMessage?             @relation(fields: [outboundMessageId], references: [id], onDelete: SetNull)
  metadata          Json?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([clinicId])
  @@index([patientId])
  @@index([appointmentId])
  @@index([status])
  @@index([expiresAt])
  @@index([outboundMessageId])
}

model PatientClinicalRecord {
  id                String                  @id @default(uuid())
  clinicId          String
  clinic            Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId         String                  @unique
  patient           Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  summary           Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  anamneses         Anamnesis[]
  clinicalNotes     ClinicalNote[]
  patientProcedures PatientProcedure[]
  patientDocuments  PatientDocumentMetadata[]

  @@index([clinicId])
}

model Anamnesis {
  id                String                  @id @default(uuid())
  clinicId          String
  clinic            Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId         String
  patient           Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinicalRecordId  String
  clinicalRecord    PatientClinicalRecord   @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
  sourceDocumentId  String?
  sourceDocument    PatientDocumentMetadata? @relation("AnamnesisSourceDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  title             String?
  data              Json
  createdByUserId   String?
  createdByName     String?
  documentDate      DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([clinicId, patientId, createdAt])
  @@index([clinicalRecordId])
}

model ClinicalNote {
  id                String                  @id @default(uuid())
  clinicId          String
  clinic            Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId         String
  patient           Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinicalRecordId  String
  clinicalRecord    PatientClinicalRecord   @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
  sourceDocumentId  String?
  sourceDocument    PatientDocumentMetadata? @relation("ClinicalNoteSourceDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  noteType          String
  title             String?
  content           Json
  status            String?
  createdByUserId   String?
  createdByName     String?
  noteDate          DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([clinicId, patientId, createdAt])
  @@index([clinicalRecordId])
}

model PatientProcedure {
  id                String                @id @default(uuid())
  clinicId          String
  clinic            Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId         String
  patient           Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinicalRecordId  String
  clinicalRecord    PatientClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
  appointmentId     String?
  appointment       Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  externalId        String?
  procedureCode     String?
  name              String
  status            String
  dentistId         String?
  dentistName       String?
  tooth             String?
  faces             String[]
  observations      String?
  registeredAt      DateTime?
  performedAt       DateTime?
  financialSnapshot Json?
  payload           Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([clinicId, patientId, createdAt])
  @@index([clinicalRecordId])
  @@index([appointmentId])
  @@index([externalId])
}

model PatientDocumentMetadata {
  id                String                @id @default(uuid())
  clinicId          String
  clinic            Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientId         String
  patient           Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinicalRecordId  String
  clinicalRecord    PatientClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
  externalDocumentId String?
  title             String?
  category          String?
  type              String?
  localPath         String?
  originalName      String?
  storedName        String?
  extension         String?
  size              Int?
  documentDate      DateTime?
  archived          Boolean               @default(false)
  archivedAt        DateTime?
  createdByUserId   String?
  createdByName     String?
  metadata          Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  anamneses         Anamnesis[]           @relation("AnamnesisSourceDocument")
  clinicalNotes     ClinicalNote[]        @relation("ClinicalNoteSourceDocument")

  @@index([clinicId, patientId, createdAt])
  @@index([clinicalRecordId])
  @@index([externalDocumentId])
  @@index([archived])
}
