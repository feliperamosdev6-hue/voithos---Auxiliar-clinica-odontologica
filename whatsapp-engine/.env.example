NODE_ENV=development
PORT=8099
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_engine?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

INTERNAL_API_TOKEN=change-me

# 32-byte key in hex (64 chars) or base64
AUTH_ENCRYPTION_KEY_HEX=
AUTH_ENCRYPTION_KEY_BASE64=

# local folder for Baileys auth files
SESSIONS_DIR=.sessions

# worker behavior
WORKER_CONCURRENCY=4
MESSAGE_MAX_ATTEMPTS=3
MESSAGE_BACKOFF_MS=4000

